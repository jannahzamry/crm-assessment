generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int        @id @default(autoincrement())
  name       String
  email      String     @unique
  password   String
  created_at DateTime   @default(now())

  customers  Customer[]

  @@map("users")
}

model Customer {
  id         Int      @id @default(autoincrement())
  name       String
  email      String?
  phone      String?
  company    String?
  created_at DateTime @default(now())

  user_id    Int
  user       User     @relation(fields: [user_id], references: [id])

  notes      Note[]

  @@map("customers")
}

model Note {
  id          Int      @id @default(autoincrement())
  content     String
  created_at  DateTime @default(now())

  customer_id Int
  customer    Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@map("notes")
}